---
import PageLayout from '@/layouts/CommonPage.astro'
import AlgorithmShowcase from '@/components/about/AlgorithmShowcase.astro'
import MusicSection from '@/components/about/MusicSection.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import { Comment } from '@/components/advanced'
import { DeferredImage } from '@/components/basic'
import { Button, DistributionSection, Icon, Label, SimpleIcon } from '@/components/user'

const headings = [
  { depth: 2, slug: 'profile', text: 'Profile' },
  { depth: 2, slug: 'education', text: 'Education' },
  { depth: 2, slug: 'research', text: 'Research' },
  { depth: 2, slug: 'daily-life', text: 'Daily Life' },
  { depth: 2, slug: 'steam', text: 'Steam' },
  { depth: 2, slug: 'bangdream', text: 'BangDream' },
  { depth: 2, slug: 'galgame', text: 'Galgame' },
  { depth: 2, slug: 'music', text: 'Music' },
  { depth: 2, slug: 'distribution', text: 'Distribution' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'copyright', text: 'Copyright' },
  { depth: 2, slug: 'theme', text: 'Theme' }
]

const distributions = [
  {
    title: 'Vercel',
    url: 'hana-blog.vercel.app',
    platform: 'Vercel'
  },
  {
    title: 'Vultr',
    url: 'hana0721.top',
    platform: 'Vultr'
  },
  {
    title: 'GitHub Pages',
    url: 'hana-blog.github.io',
    platform: 'GitHub'
  },
  {
    title: 'Cloudflare Pages',
    url: 'hana-blog.pages.dev',
    platform: 'Cloudflare'
  }
]

const favoriteGalgameStudios = [
  {
    studio: 'age',
    studioLogo: '/images/about/galgame-studios/age.png',
    officialUrl: 'https://age-soft.com',
    games: [
      {
        name: 'MUV-LUV EXTRA+UNLIMITED',
        cover: 'https://pic.hana0721.top/muvluvlogo.7pvslv04a.webp',
        officialUrl: 'https://muvluv.com/'
      },
      {
        name: 'MUV-LUV ALTERNATIVE',
        cover: 'https://pic.hana0721.top/rl-note-3.3yex1xdpri.webp',
        officialUrl: 'https://muvluv.com/'
      }
    ]
  },
  {
    studio: 'Makura',
    studioLogo: '/images/about/galgame-studios/makura.png',
    officialUrl: 'http://www.makura-soft.com/',
    games: [
      {
        name: 'Sakura no Uta',
        cover: 'https://pic.hana0721.top/Sakura_no_uta.2ksi9r6jpk.webp',
        officialUrl: 'http://www.makura-soft.com/sakuranouta/'
      },
      {
        name: 'Subarashiki Hibi',
        cover: 'https://pic.hana0721.top/wonderful.5trm6g6vbw.webp',
        officialUrl: 'http://www.keroq.co.jp/suba/'
      }
    ]
  },
  {
    studio: 'Navel',
    studioLogo: '/images/about/galgame-studios/navel.png',
    officialUrl: 'https://www.project-navel.com/',
    games: [
      {
        name: 'A Maiden\'s Rule',
        cover: 'https://pic.hana0721.top/jinyue.3goztw22av.webp',
        officialUrl: 'https://www.project-navel.com/tsukiniyorisou/'
      },
      {
        name: 'Otome Riron et son entourage -Paris Academy-',
        cover: 'https://pic.hana0721.top/lilun.7pvx8eko7.webp',
        officialUrl: 'https://www.project-navel.com/otomeriron/'
      }
    ]
  }
]
---

<PageLayout title='About' {headings} info='/about'>
  <h2 id='profile'>🧭 Profile<a class='anchor' href='#profile'>#</a></h2>
  <section class='not-prose mb-8 mt-5 rounded-xl border border-border bg-card p-4 sm:p-5'>
    <div class='grid gap-4 lg:grid-cols-[minmax(0,1fr)_220px] lg:items-start'>
      <div class='flex h-full flex-col'>
        <div class='flex flex-col gap-4 sm:flex-row sm:items-center'>
          <DeferredImage
            src='/avatar/avatar.png'
            alt='Profile avatar'
            class='h-24 w-24 rounded-lg border p-1 object-cover'
            loading='eager'
            fetchpriority='high'
            defer={false}
            />
          <div class='flex-1'>
            <p class='m-0 text-lg font-semibold text-foreground'>菊花花</p>
            <p class='mt-1 text-sm text-muted-foreground'>Master Student @ NUDT</p>
            <div class='mt-3 flex flex-wrap gap-2'>
              <Label title='China'>
                <Icon name='location' class='size-4' slot='icon' />
              </Label>
              <Label
                title='Github'
                as='a'
                href='https://github.com/Minakanmi-Yuki'
                target='_blank'
                rel='noopener noreferrer'
              >
                <Icon name='github' class='size-4' slot='icon' />
              </Label>
              <Label title='Email' as='a' href='mailto:2849633943@qq.com'>
                <Icon name='email' class='size-4' slot='icon' />
              </Label>
            </div>
          </div>
        </div>
        <p class='mt-4 text-sm text-muted-foreground'>
          I’m an outgoing person who smiles a lot. If someone around me needs help, I’ll usually jump in first. Even small help makes me genuinely happy. During the day, I’m mostly in “little sunshine” mode.
        </p>
        <p class='mt-2 text-sm text-muted-foreground'>
          I enjoy chatting and usually don’t let conversations go cold. I’m still learning to balance my enthusiasm, since I can sometimes come across as a bit clingy. Overall, I’m opinionated and driven by a strong moral compass, though at night I occasionally get a little emo.
        </p>
        <div class='mt-auto pt-4'>
          <Button title='Sponsor Me' class='w-fit' href='projects#sponsorship' style='ahead' />
        </div>
      </div>
      <aside class='rounded-lg bg-card p-3'>
        <p class='m-0 text-xs uppercase tracking-wide text-muted-foreground'>MBTI</p>
        <p class='mt-1 text-lg font-semibold text-foreground'>ENFJ-A</p>
        <DeferredImage
          src='/images/profile/enfj-protagonist-standing.svg'
          alt='ENFJ Protagonist'
          class='mt-3 w-full'
          loading='eager'
          fetchpriority='high'
          defer={false}
          />
      </aside>
    </div>
  </section>

  <h2 id='education'>🎓 Education<a class='anchor' href='#education'>#</a></h2>
  <section class='not-prose mb-8 mt-5 grid grid-cols-1 gap-4'>
    <article class='rounded-xl border border-border bg-card transition-shadow hover:shadow-md'>
      <a
        href='https://www.scnu.edu.cn/'
        target='_blank'
        rel='noopener noreferrer'
        class='block rounded-xl p-4 no-underline sm:p-5'
        aria-label='Open South China Normal University official website'
      >
        <div class='flex items-start gap-3'>
          <div class='size-20 shrink-0 overflow-hidden rounded-md bg-transparent'>
            <DeferredImage
              src='/images/education/scnu-badge.png'
              alt='South China Normal University badge'
              class='h-full w-full object-contain'
              />
          </div>
          <div>
            <div class='mb-1 text-sm font-medium text-muted-foreground'>Undergraduate</div>
            <h3 class='m-0 text-base font-semibold text-foreground'>South China Normal University</h3>
            <p class='mt-2 text-sm text-muted-foreground'>Artificial Intelligence, B.Eng.</p>
            <p class='mt-1 text-xs text-muted-foreground'>Period: 2021 - 2025</p>
          </div>
        </div>
      </a>
    </article>
    <article class='rounded-xl border border-border bg-card transition-shadow hover:shadow-md'>
      <a
        href='https://www.nudt.edu.cn/'
        target='_blank'
        rel='noopener noreferrer'
        class='block rounded-xl p-4 no-underline sm:p-5'
        aria-label='Open National University of Defense Technology official website'
      >
        <div class='flex items-start gap-3'>
          <div class='size-20 shrink-0 overflow-hidden rounded-md bg-transparent'>
            <DeferredImage
              src='/images/education/nudt-badge.png'
              alt='National University of Defense Technology badge'
              class='h-full w-full object-contain'
              />
          </div>
          <div>
            <div class='mb-1 text-sm font-medium text-muted-foreground'>Master's</div>
            <h3 class='m-0 text-base font-semibold text-foreground'>National University of Defense Technology</h3>
            <p class='mt-2 text-sm text-muted-foreground'>Electronic Information, M.Eng.</p>
            <p class='mt-1 text-xs text-muted-foreground'>Period: 2025 - Present</p>
          </div>
        </div>
      </a>
    </article>
  </section>

  <h2 id='research'>🔬 Research<a class='anchor' href='#research'>#</a></h2>
  <div class='not-prose mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3'>
    {
      [
        {
          title: 'Robotics Manipulation',
          description: 'Robotic Manipulation, Grasping, Dexterous Control, Object Interaction',
          icon: 'ros'
        },
        {
          title: 'VLA',
          description: 'Vision-Language-Action Models, Multi-modal Learning, Embodied AI',
          icon: 'pytorch'
        },
        {
          title: 'Multi-Agent System',
          description: 'Cooperative MARL, Value Decomposition Methods',
          icon: 'kubernetes'
        }
      ].map((interest) => (
        <div class='group relative overflow-hidden rounded-xl border border-border bg-card p-4 transition-all hover:border-foreground/25 hover:shadow-md'>
          <div class='flex items-start gap-4'>
            <div class='flex size-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 transition-colors group-hover:bg-primary/20'>
              <SimpleIcon
                class='size-5 text-primary transition-transform duration-300 group-hover:scale-110'
                name={interest.icon}
              />
            </div>
            <div class='flex-1'>
              <p class='text-xl font-medium leading-tight text-foreground transition-colors group-hover:text-primary'>
                {interest.title}
              </p>
              <p class='text-sm leading-relaxed text-muted-foreground'>{interest.description}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <h2 id='daily-life'>📸 Daily Life<a class='anchor' href='#daily-life'>#</a></h2>
  <p>
    Besides studying and gaming, my daily life is simple and happy: going out for good food with friends and occasionally singing at KTV to relax.
  </p>
  <section class='not-prose mb-8 mt-5 grid grid-cols-1 gap-4 lg:grid-cols-2'>
    <article class='rounded-xl border border-border bg-card p-4'>
      <h3 class='mb-3 text-base font-semibold text-foreground'>Food Moments</h3>
      <div class='grid grid-cols-2 gap-3'>
        <figure class='rounded-lg border border-border/70 bg-card p-2'>
          <DeferredImage
            src='https://pic.hana0721.top/food1.8adut11vdc.webp'
            alt='Food photo 1'
            class='aspect-[4/3] w-full rounded-md object-cover'
            />
          <figcaption class='px-1 pt-1.5 text-xs text-muted-foreground'>Love grilled oysters ~</figcaption>
        </figure>
        <figure class='rounded-lg border border-border/70 bg-card p-2'>
          <DeferredImage
            src='https://pic.hana0721.top/food2.4clhccquq2.webp'
            alt='Food photo 2'
            class='aspect-[4/3] w-full rounded-md object-cover'
            />
          <figcaption class='px-1 pt-1.5 text-xs text-muted-foreground'>Love stir-fried clams ~</figcaption>
        </figure>
        <figure class='rounded-lg border border-border/70 bg-card p-2'>
          <DeferredImage
            src='https://pic.hana0721.top/food3.2a5ooas9ol.webp'
            alt='Food photo 3'
            class='aspect-[4/3] w-full rounded-md object-cover'
            />
          <figcaption class='px-1 pt-1.5 text-xs text-muted-foreground'>Love BBQ skewers ~</figcaption>
        </figure>
        <figure class='rounded-lg border border-border/70 bg-card p-2'>
          <DeferredImage
            src='https://pic.hana0721.top/food4.7lkl90eccf.webp'
            alt='Food photo 4'
            class='aspect-[4/3] w-full rounded-md object-cover'
            />
          <figcaption class='px-1 pt-1.5 text-xs text-muted-foreground'>Love hot-oil braised noodles ~</figcaption>
        </figure>
      </div>
    </article>

    <article class='rounded-xl border border-border bg-card p-4'>
      <h3 class='mb-3 text-base font-semibold text-foreground'>Karaoke Nights</h3>
      <div class='grid grid-cols-2 gap-3'>
        <figure class='rounded-lg border border-border/70 bg-card p-2'>
          <DeferredImage
            src='https://pic.hana0721.top/ktv.9gx61n20aj.webp'
            alt='Karaoke photo 1'
            class='aspect-[4/3] w-full rounded-md object-cover'
            />
          <figcaption class='px-1 pt-1.5 text-xs text-muted-foreground'>MYGO version of “Butter-Fly”</figcaption>
        </figure>
        <figure class='rounded-lg border border-border/70 bg-card p-2'>
          <DeferredImage
            src='https://pic.hana0721.top/ktv.36263rd6gs.webp'
            alt='Karaoke photo 2'
            class='aspect-[4/3] w-full rounded-md object-cover'
            />
          <figcaption class='px-1 pt-1.5 text-xs text-muted-foreground'>“Sakura no Uta”</figcaption>
        </figure>
        <figure class='rounded-lg border border-border/70 bg-card p-2'>
          <DeferredImage
            src='https://pic.hana0721.top/ktv.32ik61k3r0.webp'
            alt='Karaoke photo 3'
            class='aspect-[4/3] w-full rounded-md object-cover'
            />
          <figcaption class='px-1 pt-1.5 text-xs text-muted-foreground'>“Eternal Feather”</figcaption>
        </figure>
        <figure class='rounded-lg border border-border/70 bg-card p-2'>
          <DeferredImage
            src='https://pic.hana0721.top/ktv.1hst6kmwak.webp'
            alt='Karaoke photo 4'
            class='aspect-[4/3] w-full rounded-md object-cover'
            />
          <figcaption class='px-1 pt-1.5 text-xs text-muted-foreground'>“Always in my heart”</figcaption>
        </figure>
      </div>
    </article>
  </section>

  <h2 id='steam'>🎮 Steam<a class='anchor' href='#steam'>#</a></h2>
  <p>
    On Steam, I mostly play Slay the Spire, Don't Starve Together, and Left 4 Dead. I also play various AAA titles and party games like Phasmophobia, Content Warning, and Lethal Company. I also have a bit of a collection habit and keep quite a few Galgames in my library.
  </p>
  <p>
    Slay the Spire is the game I've spent the most time on, with 2000+ hours. My current best records are a 179-win Silent streak in SL and a 10-win streak in NOSL. I keep writing guides in my <a href='/collection/sts-guide'>Slay The Spire guide collection</a>, and recently I also started playing Slay the Spire 2.
  </p>
  <p>
    In Don't Starve Together, I mainly play Wigfrid and also made a high-quality guide on Bilibili: <a href='https://www.bilibili.com/video/BV1MwGNz6EGF/'>Wigfrid Guide Collection</a>. As for Left 4 Dead, I usually play Campaign or Realism Versus, and I am not very good at it.
  </p>
  <p>
    Here is my Steam profile: <a href='https://steamcommunity.com/profiles/76561199033212179/'>菊花花zako</a>. Feel free to add me and play together.
  </p>
  <a
    href='https://steamcommunity.com/profiles/76561199033212179/'
    target='_blank'
    rel='noopener noreferrer'
    aria-label='Steam profile screenshot'
  >
    <DeferredImage
      src='https://pic.hana0721.top/steam.7pvxaowx7.webp'
      alt='Steam profile screenshot'
      class='my-4 rounded-xl border border-border'
      />
  </a>
  <section class='not-prose mt-6 rounded-xl border border-border bg-card p-4'>
    <h3 class='mb-3 text-base font-semibold text-foreground'>Screen Shot</h3>
    <div class='grid grid-cols-1 gap-3 sm:grid-cols-3'>
      <figure class='overflow-hidden rounded-lg border border-border/70 bg-card'>
        <DeferredImage
          src='https://pic.hana0721.top/IMG_4636.6t7prarkj0.webp'
          alt='Steam screenshot 1'
          class='aspect-video w-full object-cover'
          />
      </figure>
      <figure class='overflow-hidden rounded-lg border border-border/70 bg-card'>
        <DeferredImage
          src='https://pic.hana0721.top/IMG_4650.175zdfq9pq.webp'
          alt='Steam screenshot 2'
          class='aspect-video w-full object-cover'
          />
      </figure>
      <figure class='overflow-hidden rounded-lg border border-border/70 bg-card'>
        <DeferredImage
          src='https://pic.hana0721.top/0BFA5C2A5FE5E4E0480CB0DFC3F2156B.9o0dx36ran.webp'
          alt='Steam screenshot 3'
          class='aspect-video w-full object-cover'
          />
      </figure>
      <figure class='overflow-hidden rounded-lg border border-border/70 bg-card'>
        <DeferredImage
          src='https://pic.hana0721.top/IMG_7192.45i9gxyj76.webp'
          alt='Steam screenshot 4'
          class='aspect-video w-full object-cover'
          />
      </figure>
      <figure class='overflow-hidden rounded-lg border border-border/70 bg-card'>
        <DeferredImage
          src='https://pic.hana0721.top/2026-03-13_16.10.10.9gx61nklvd.webp'
          alt='Steam screenshot 5'
          class='aspect-video w-full object-cover'
          />
      </figure>
      <figure class='overflow-hidden rounded-lg border border-border/70 bg-card'>
        <DeferredImage
          src='https://pic.hana0721.top/IMG_5120.3yf1libhga.webp'
          alt='Steam screenshot 6'
          class='aspect-video w-full object-cover'
          />
      </figure>
    </div>
  </section>

  <h2 id='bangdream'>🎤 BangDream<a class='anchor' href='#bangdream'>#</a></h2>
  <p>
    I'm still a beginner in BanG Dream!, and Poppin'Party is my #1 forever. Here are my account and gameplay screenshots.
  </p>

  <div class='not-prose mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-2'>
    <div class='group overflow-hidden rounded-xl border border-border bg-card transition-all hover:shadow-lg'>
      <div class='relative aspect-video overflow-hidden rounded-lg bg-muted'>
        <DeferredImage
          src='https://pic.hana0721.top/ea2045a7b0b4584969ad05ac9b02a7d3.8l0okklbjh.webp'
          alt='My game account'
          class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
          />
      </div>
      <div class='p-3'>
        <p class='text-sm font-medium text-foreground'>This is my game account ~</p>
      </div>
    </div>

    <div class='group overflow-hidden rounded-xl border border-border bg-card transition-all hover:shadow-lg'>
      <div class='relative aspect-video overflow-hidden rounded-lg bg-muted'>
        <DeferredImage
          src='https://pic.hana0721.top/063075ddf24f7670a7ce227937b83c76.41ynhlglja.webp'
          alt='My PPP lineup level'
          class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
          />
      </div>
      <div class='p-3'>
        <p class='text-sm font-medium text-foreground'>My PPP team level</p>
      </div>
    </div>

    <div class='group overflow-hidden rounded-xl border border-border bg-card transition-all hover:shadow-lg'>
      <div class='relative aspect-video overflow-hidden rounded-lg bg-muted'>
        <DeferredImage
          src='https://pic.hana0721.top/3c45bcd41d6d683574ae0e97ee7fd048.7pvymz49f.webp'
          alt='Poppin Party'
          class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
          />
      </div>
      <div class='p-3'>
        <p class='text-sm font-medium text-foreground'>Poppin'Party my beloved ~</p>
      </div>
    </div>

    <div class='group overflow-hidden rounded-xl border border-border bg-card transition-all hover:shadow-lg'>
      <div class='relative aspect-video overflow-hidden rounded-lg bg-muted'>
        <DeferredImage
          src='https://pic.hana0721.top/bangdream-4.8dxgp52t72.webp'
          alt='Grinding rank'
          class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
          />
      </div>
      <div class='p-3'>
        <p class='text-sm font-medium text-foreground'>Grinding rank is tiring ...</p>
      </div>
    </div>

    <div class='group overflow-hidden rounded-xl border border-border bg-card transition-all hover:shadow-lg'>
      <div class='relative aspect-video overflow-hidden rounded-lg bg-muted'>
        <DeferredImage
          src='https://pic.hana0721.top/bangdream-5.3k8lt0is15.webp'
          alt='OTAE'
          class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-110'
