---
interface Props {
  name: string
  rarity: string
  type: string
  cost: string
  effect: string
  image?: string
  score?: number
}

const {
  name,
  rarity,
  type,
  cost,
  effect,
  image = '/images/sts-card-placeholder.svg',
  score = 0
} = Astro.props as Props
const normalizedScore = Math.max(0, Math.min(10, Number(score) || 0))
const scoreText = Number.isInteger(normalizedScore) ? `${normalizedScore}` : normalizedScore.toFixed(1)
const whole = Math.floor(normalizedScore)
const fraction = normalizedScore - whole

const blocks = Array.from({ length: 10 }, (_, index) => {
  const step = index + 1
  if (step <= whole) return 1
  if (step === whole + 1 && fraction > 0) return fraction
  return 0
})

const anchorId = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
---

<article id={anchorId} class='rounded-xl border p-4'>
  <div class='flex flex-col gap-4 sm:flex-row'>
    <div class='mx-auto w-40 shrink-0 sm:mx-0 lg:w-44'>
      <img
        src={image}
        alt={`${name} card image placeholder`}
        class='aspect-[5/7] w-full rounded-lg object-contain'
        loading='lazy'
        decoding='async'
        fetchpriority='low'
      />
    </div>

    <div class='min-w-0 flex-1'>
      <div class='mb-3 flex flex-wrap gap-2 text-xs'>
        <span class='rounded-full border bg-muted px-2.5 py-1'>稀有度 Rarity: {rarity}</span>
        <span class='rounded-full border bg-muted px-2.5 py-1'>类型 Type: {type}</span>
        <span class='rounded-full border bg-muted px-2.5 py-1'>费用 Cost: {cost}</span>
      </div>

      <p class='text-sm text-muted-foreground'>
        <span class='font-medium text-foreground/80'>Effect:</span> {effect}
      </p>
      <div class='mt-3 text-sm text-muted-foreground'>
        <slot />
      </div>
    </div>
  </div>

  <div class='mt-4 rounded-xl border bg-muted/70 px-3 py-2'>
    <div class='mb-2 flex items-center justify-between text-sm'>
      <span class='text-muted-foreground'>评分 Rating</span>
      <span class='font-medium text-foreground'>{scoreText} / 10</span>
    </div>
    <div class='grid grid-cols-10 gap-1'>
      {
        blocks.map((fill) => (
          <span class='score-block h-2.5 rounded-full border border-border/80' style={`--fill:${Math.round(fill * 100)}%`} />
        ))
      }
    </div>
  </div>
</article>

<style>
  .score-block {
    background: linear-gradient(
      to right,
      hsl(var(--primary)) 0%,
      hsl(var(--primary)) var(--fill),
      hsl(var(--background)) var(--fill),
      hsl(var(--background)) 100%
    );
  }
</style>
