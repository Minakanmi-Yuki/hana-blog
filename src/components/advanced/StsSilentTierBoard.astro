] as const

function slugify(name: string) {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
}
---

<section>
  <div class='space-y-2 rounded-xl border bg-card p-2 sm:p-3'>
    {tiers.map((tier) => (
      <div class='flex gap-2'>
        <div class={`flex w-14 shrink-0 items-center justify-center rounded-lg text-lg font-bold sm:w-16 ${tier.color}`}>{tier.label}</div>
        <div class='flex min-h-20 flex-1 flex-wrap gap-1 rounded-lg bg-muted/35 p-1.5 sm:gap-2'>
          {tier.cards.map((card) => (
            <a href={`#${slugify(card)}`} title={card} class='group block'>
              <img
                src='data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs='
                data-src={imageMap[card]}
                alt={card}
                loading='lazy'
                decoding='async'
                fetchpriority='low'
                class='h-16 w-auto object-cover transition-transform duration-150 group-hover:-translate-y-0.5 sm:h-20'
              />
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const lazyImgs = Array.from(document.querySelectorAll<HTMLImageElement>('img[data-src]'))
  const load = (img: HTMLImageElement) => {
    const realSrc = img.getAttribute('data-src')
    if (!realSrc) return
    img.setAttribute('src', realSrc)
    img.removeAttribute('data-src')
  }

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return
          const img = entry.target as HTMLImageElement
          load(img)
          observer.unobserve(img)
        })
      },
      { rootMargin: '200px 0px' }
    )

    lazyImgs.forEach((img) => observer.observe(img))
  } else {
    lazyImgs.forEach(load)
  }
</script>
